PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/academic_notes
JWT_SECRET=replace_with_a_strong_secret
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_IDS=web_client_id.apps.googleusercontent.com,android_client_id.apps.googleusercontent.com,ios_client_id.apps.googleusercontent.com
DNS_SERVERS=8.8.8.8,1.1.1.1
CLIENT_ORIGIN=*

# Optional: if set, backend will create/promote this user as admin at startup.
ADMIN_NAME=Main Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
